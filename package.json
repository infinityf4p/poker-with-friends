{
  "name": "poker-with-friends",
  "version": "0.4.2",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.13.1",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build:packages": "pnpm --filter @poker-with-friends/protocol --filter @poker-with-friends/engine --filter @poker-with-friends/db build",
    "predev": "pnpm build:packages",
    "dev": "pnpm --parallel --filter @poker-with-friends/server --filter @poker-with-friends/web dev",
    "build": "pnpm -r --if-present build",
    "typecheck": "pnpm build:packages && pnpm -r --if-present typecheck",
    "test": "pnpm build:packages && pnpm -r --if-present test",
    "test:e2e": "pnpm build:packages && pnpm --filter @poker-with-friends/server test:e2e",
    "test:property": "pnpm --filter @poker-with-friends/engine test:property",
    "db:generate": "pnpm --filter @poker-with-friends/db db:generate",
    "db:migrate": "pnpm --filter @poker-with-friends/db db:migrate",
    "format:check": "prettier --check .",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@types/node": "^24.0.15",
    "prettier": "^3.6.2",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
