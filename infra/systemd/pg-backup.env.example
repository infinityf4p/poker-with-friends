# Installed as /etc/poker-with-friends/pg-backup.env (root:root, mode 0600).
# Docker mode uses pg_dump/pg_restore from the PostgreSQL container.
PG_BACKUP_MODE=docker
PG_CONTAINER=poker-with-friends-postgres
PGDATABASE=poker
PGUSER=poker
PG_BACKUP_DIR=/var/backups/poker/postgres
PG_BACKUP_KEEP_DAILY=7
PG_BACKUP_KEEP_WEEKLY=4
PG_BACKUP_TIMEZONE=UTC

# For host mode, also set PGHOST/PGPORT and configure PGPASSFILE rather than
# putting a password on the command line.
# PG_BACKUP_MODE=host
# PGHOST=127.0.0.1
# PGPORT=5432
# PGPASSFILE=/etc/poker-with-friends/pgpass
