# Copy this file to infra/.env before running Docker Compose. The copied file is
# ignored by Git. Replace every REPLACE_* value and keep the file mode at 0600.

COMPOSE_PROJECT_NAME=poker-with-friends
APP_IMAGE_REPOSITORY=poker-with-friends-app
APP_IMAGE_TAG=latest
APP_BUILD_SHA=unknown
APP_BIND_ADDRESS=127.0.0.1
APP_BIND_PORT=3000

PUBLIC_ORIGIN=https://poker.example.com

POSTGRES_IMAGE=postgres:18-alpine
POSTGRES_CONTAINER_NAME=poker-with-friends-postgres
POSTGRES_USER=poker
POSTGRES_PASSWORD=REPLACE_WITH_A_STRONG_DATABASE_PASSWORD
POSTGRES_DB=poker
# Optional: set an absolute host path (for example /srv/poker/postgres) instead
# of the default Docker named volume. Create it with the correct owner first.
# POSTGRES_DATA_PATH=/srv/poker/postgres
# URL-encode reserved password characters if you do not use the generator.
DATABASE_URL=postgres://poker:REPLACE_WITH_URL_ENCODED_DATABASE_PASSWORD@postgres:5432/poker

# Generate independently:
#   openssl rand -base64 48  # COOKIE_SECRET and TOKEN_PEPPER
#   openssl rand -base64 32  # SNAPSHOT_KEY (exactly 32 bytes before encoding)
COOKIE_SECRET=REPLACE_WITH_AT_LEAST_32_RANDOM_BYTES
TOKEN_PEPPER=REPLACE_WITH_AT_LEAST_32_RANDOM_BYTES
SNAPSHOT_KEY=REPLACE_WITH_BASE64_ENCODED_32_BYTE_KEY

ADMIN_USERNAME=admin
# Generate with `pnpm --filter @poker-with-friends/server admin:hash`; never store plaintext.
# The production environment generator in DEPLOYMENT.md can create this too.
ADMIN_PASSWORD_HASH='REPLACE_WITH_ARGON2ID_HASH'

RETENTION_DAYS=30
ROOM_IDLE_HOURS=12
